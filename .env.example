DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_ALL_ORIGINS=True

# Production: set DATABASE_URL to your hosted PostgreSQL connection string.
DATABASE_URL=

# Local development defaults to SQLite via db.sqlite3.
# Set USE_LOCAL_POSTGRES=True only if you want to run against a local PostgreSQL instance.
USE_LOCAL_POSTGRES=False

# Optional local PostgreSQL settings when USE_LOCAL_POSTGRES=True
DB_NAME=lost_and_found_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=prefer
DB_CONN_MAX_AGE=60

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Use Django static finders (handy on some platforms); default is DEBUG.
WHITENOISE_USE_FINDERS=False
